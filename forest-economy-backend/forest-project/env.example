# 复制为 .env 或导出为环境变量，勿提交 .env 或真实密钥到仓库。
# 后端运行前必须设置 JWT_SECRET_BASE64、DB_PASSWORD。

# 数据库（必填）
DB_URL=jdbc:mysql://localhost:3306/forest-economy
DB_USERNAME=root
DB_PASSWORD=

# JWT（必填）：Base64 编码的密钥，建议 32+ 字节原文再 Base64，例如: echo -n "your-32-byte-secret-key-here" | base64
JWT_SECRET_BASE64=
JWT_EXPIRATION_MS=2592000000

# 限流（可选）
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_LOGIN_PER_IP=30
# RATE_LIMIT_REGISTER_PER_IP=10
# RATE_LIMIT_API_PER_IP=300

# RAG 服务（可选，未配置时问答接口返回 503）
# RAG_SERVICE_URL=http://localhost:8000
# RAG_TIMEOUT_SECONDS=60
